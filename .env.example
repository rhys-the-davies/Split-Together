# Supabase — find these in your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-only. Never prefix with NEXT_PUBLIC_.

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App URL — no trailing slash
# Development:  http://localhost:3000
# Production:   https://your-vercel-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron protection (M12) — generate with: openssl rand -hex 32
CRON_SECRET=

# Supabase project ID — used by `npm run db:types`
# Find this in your Supabase project URL: https://supabase.com/dashboard/project/<id>
SUPABASE_PROJECT_ID=
